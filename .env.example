# Copy this file to .env and fill in your values.
# On Vercel, add these in: Project Settings → Environment Variables

# PostgreSQL connection string (required)
# Use Neon for free serverless Postgres: https://neon.tech
# The Neon connection string looks like:
#   postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
#
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Admin panel password — change this before deploying!
# Must match what you type in the login screen.
ADMIN_TOKEN=autoassets2024

# Local API server port (only used when running locally with `npm run start`)
PORT=3000
